# Data credentials
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# FastAPI server
# FASTAPI_PORT is also used as the host-side Docker port (maps to internal container port 8000)
FASTAPI_PORT=8000
FASTAPI_HOST=localhost
SECRET_KEY=

# Database
# POSTGRES_* vars are used by docker-compose.yml to create the DB and expose it on the host.
# POSTGRES_PORT controls the host-side port (default 5432). Change it if 5432 is already taken.
POSTGRES_USER=finance
POSTGRES_PASSWORD=finance
POSTGRES_DB=finance_board
POSTGRES_PORT=5432
# SQLALCHEMY_DATABASE_URI is used for local dev only — docker-compose.yml overrides it automatically.
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://<username>:<password>@localhost:<port>/<database>

# Mindee
MINDEE_API_KEY=
MINDEE_MODEL_ID=

# Stock prices
TWELVE_DATA_API_KEY=
