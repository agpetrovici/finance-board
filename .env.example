# Data credentials
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# FastAPI server
# FASTAPI_PORT is also used as the host-side Docker port (maps to internal container port 8000)
FASTAPI_PORT=8000
FASTAPI_HOST=localhost
SECRET_KEY=

# Database (local dev only — overridden automatically by docker-compose.yml)
SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://<username>:<password>@<host>:<port>/<database>

# Mindee
MINDEE_API_KEY=
MINDEE_MODEL_ID=

# Stock prices
TWELVE_DATA_API_KEY=
